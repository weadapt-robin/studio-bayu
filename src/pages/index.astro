---
import '../styles/globals.css';

const title = "Studio Bayu — Brengt projecten in beweging";
const description = "Operations & (lead) projectmanagement voor agencies en brands. Studio Bayu structureert, stuurt en realiseert complexe projecten.";
const domain = "studiobayu.com";
---

<!DOCTYPE html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={`https://${domain}/`} />

    <link rel="preload" href="/fonts/TAN-Nimbus.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/Quicksand-Regular.ttf" as="font" type="font/ttf" crossorigin />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={`https://${domain}/`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`https://${domain}/og-preview.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Studio Bayu" />
    <meta property="og:locale" content="nl_NL" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`https://${domain}/og-preview.png`} />

    <link rel="icon" href="/favicon.png" />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {"@type":"ListItem","position":1,"name":"Home","item":`https://${domain}`}
      ]
    })} />
  </head>
  <body>
    <header class="site-header">
      <div class="container site-header__inner">
        <a href="/" class="site-header__logo" aria-label="Studio Bayu, terug naar home">
          <span class="logo-mark logo-mark--sm" aria-hidden="true"></span>
        </a>
        <nav class="site-header__nav" aria-label="Hoofdnavigatie">
          <a href="/studio">Studio</a>
          <a href="/services">Services</a>
          <a href="/projecten">Projecten</a>
          <a href="/ervaringen">Ervaringen</a>
          <a href="/contact">Contact</a>
        </nav>
      </div>
    </header>

    <main>

      <!-- ============ HERO ============ -->
      <section class="band band--light band--hero">
        <div class="container hero">
          <div class="hero__copy">
            <span class="logo-mark logo-mark--md" role="img" aria-label="Studio Bayu"></span>
            <h1>Brengt projecten<br /> in beweging.</h1>
            <p class="lead">
              Operations & (lead) projectmanagement voor agencies en brands.
            </p>
            <p>
              Ik help teams en organisaties om complexe projecten te structureren, aan te sturen
              en te realiseren. Van strategie tot uitvoering. Met focus op overzicht,
              samenwerking en een soepel lopende operatie.
            </p>
            <div class="hero__cta">
              <a href="/contact" class="btn btn--primary">Kennismaken</a>
              <a href="/services" class="btn btn--ghost">Services</a>
            </div>
          </div>
          <div class="hero__visual">
            <div class="placeholder placeholder--portrait">
              <span class="eyebrow">Portret · placeholder</span>
            </div>
          </div>
        </div>
      </section>

      <!-- ============ INTRO / OUR STORY ============ -->
      <section class="band band--light">
        <div class="container split split--image-left fade-up">
          <div class="split__media">
            <div class="placeholder placeholder--portrait">
              <span class="eyebrow">Afbeelding · placeholder</span>
            </div>
          </div>
          <div class="split__copy">
            <span class="eyebrow">Onze introductie</span>
            <h2>Structuur waar ideeën <em>om vragen.</em></h2>
            <p>
              In veel agencies en creatieve organisaties zit de uitdaging niet in ideeën,
              maar in uitvoering. Projecten lopen parallel, prioriteiten verschuiven, teams
              schakelen constant en overzicht raakt versnipperd. Studio Bayu brengt daar
              structuur in.
            </p>
            <p>
              Ik werk op het snijvlak van operations en projectmanagement en zorg dat
              projecten niet alleen starten, maar ook daadwerkelijk worden afgerond.
              Op tijd, binnen scope en met grip op proces en team.
            </p>
          </div>
        </div>
      </section>

      <!-- ============ WAT STUDIO BAYU DOET (deep band, zoals SEREIN) ============ -->
      <section class="band band--deep fade-up">
        <div class="container showcase">
          <div class="showcase__heading">
            <span class="eyebrow eyebrow--inverse">Wat Studio Bayu doet</span>
            <h2>Helder. Stuurbaar. Voorspelbaar.</h2>
          </div>
          <div class="showcase__grid">
            <figure class="pillar">
              <div class="placeholder placeholder--square placeholder--on-deep">
                <span class="eyebrow eyebrow--inverse">01</span>
              </div>
              <figcaption>
                <h3>Heldere structuren</h3>
              </figcaption>
            </figure>
            <figure class="pillar">
              <div class="placeholder placeholder--square placeholder--on-deep">
                <span class="eyebrow eyebrow--inverse">02</span>
              </div>
              <figcaption>
                <h3>Sterke aansturing</h3>
              </figcaption>
            </figure>
            <figure class="pillar">
              <div class="placeholder placeholder--square placeholder--on-deep">
                <span class="eyebrow eyebrow--inverse">03</span>
              </div>
              <figcaption>
                <h3>Voorspelbare uitvoering</h3>
              </figcaption>
            </figure>
          </div>
          <p class="showcase__body">
            Studio Bayu ondersteunt agencies en brands in het realiseren van projecten die
            complex, dynamisch of multidisciplinair zijn. Zodat teams beter kunnen werken en
            projecten minder afhankelijk zijn van ad hoc schakelen.
          </p>
        </div>
      </section>

      <!-- ============ SERVICES PREVIEW ============ -->
      <section class="band band--alt">
        <div class="container services">
          <header class="services__heading fade-up">
            <span class="eyebrow">Services</span>
            <h2>Drie manieren waarop ik werk.</h2>
          </header>

          <div class="services__grid">
            <article class="service-card fade-up">
              <div class="placeholder placeholder--portrait">
                <span class="eyebrow">01</span>
              </div>
              <div class="service-card__body">
                <h3>(Lead) Projectmanagement</h3>
                <p>
                  Ik stuur projecten van begin tot eind aan en bewaak planning, scope, budget
                  en kwaliteit. Van het vertalen van strategie naar concrete planning tot
                  dagelijkse coördinatie en stakeholdermanagement. Inzetbaar als projectmanager
                  of lead binnen bestaande teams.
                </p>
                <a href="/services#projectmanagement" class="link-arrow">Meer over projectmanagement</a>
              </div>
            </article>

            <article class="service-card fade-up">
              <div class="placeholder placeholder--portrait">
                <span class="eyebrow">02</span>
              </div>
              <div class="service-card__body">
                <h3>Operations & procesoptimalisatie</h3>
                <p>
                  Ik analyseer hoe teams en organisaties werken en breng structuur aan waar dat
                  ontbreekt. Denk aan workflow optimalisatie, interne processen, rolverdeling
                  en werkstructuren die schaalbaar zijn.
                </p>
                <a href="/services#operations" class="link-arrow">Meer over operations</a>
              </div>
            </article>

            <article class="service-card fade-up">
              <div class="placeholder placeholder--portrait">
                <span class="eyebrow">03</span>
              </div>
              <div class="service-card__body">
                <h3>Events & weddings <span class="subtle">(selectief)</span></h3>
                <p>
                  Naast mijn werk voor agencies en brands begeleid ik selectief events en
                  bruiloften. Altijd met dezelfde aanpak: overzicht, structuur en aandacht
                  voor detail in uitvoering.
                </p>
                <a href="/services#events" class="link-arrow">Meer over events</a>
              </div>
            </article>
          </div>
        </div>
      </section>

      <!-- ============ VOOR WIE (Our Philosophy-style split, image rechts) ============ -->
      <section class="band band--light">
        <div class="container split split--image-right fade-up">
          <div class="split__copy">
            <span class="eyebrow">Voor wie</span>
            <h2>Studio Bayu werkt met…</h2>
            <ul class="feature-list">
              <li>agencies en brands die meerdere projecten tegelijk draaien</li>
              <li>teams met behoefte aan structuur in de operatie</li>
              <li>organisaties die willen opschalen zonder chaos</li>
              <li>opdrachtgevers die iemand zoeken die verantwoordelijkheid neemt in uitvoering</li>
            </ul>
          </div>
          <div class="split__media">
            <div class="placeholder placeholder--portrait">
              <span class="eyebrow">Afbeelding · placeholder</span>
            </div>
          </div>
        </div>
      </section>

      <!-- ============ CTA ============ -->
      <section class="band band--deep fade-up">
        <div class="container cta">
          <span class="eyebrow eyebrow--inverse">Kennismaken</span>
          <h2>Klaar om je operatie in beweging te brengen?</h2>
          <p>
            Wil je weten of Studio Bayu past bij jouw organisatie of project? Neem contact op
            voor een kennismaking.
          </p>
          <a href="/contact" class="btn btn--inverse">Neem contact op</a>
        </div>
      </section>

    </main>

    <!-- ============ FOOTER ============ -->
    <footer class="site-footer">
      <div class="container site-footer__inner">
        <a href="/" class="site-footer__logo" aria-label="Studio Bayu, terug naar home">
          <span class="logo-mark logo-mark--md" aria-hidden="true"></span>
        </a>
        <nav class="site-footer__nav" aria-label="Footer">
          <a href="/services">Projectmanagement</a>
          <a href="/services">Operations</a>
          <a href="/services">Events</a>
          <a href="/contact">Contact</a>
        </nav>
        <p class="site-footer__mail">
          <a href="mailto:lize@studiobayu.com">lize@studiobayu.com</a>
        </p>
      </div>
    </footer>

    <script is:inline>
      const io = new IntersectionObserver((entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            io.unobserve(entry.target);
          }
        }
      }, { rootMargin: '-10% 0px', threshold: 0.05 });
      document.querySelectorAll('.fade-up').forEach((el) => io.observe(el));
    </script>

    <style is:global>
      /* ==========================================================
         Homepage — page-specifieke styles
         (globale tokens + base zitten in src/styles/globals.css)
         ========================================================== */

      /* Outer frame effect — body = Sand; header/bands/footer zijn losstaande blokken
         met margin-inline zodat de Sand-frame door alle kanten zichtbaar blijft */
      body {
        background: var(--bg-alt);
      }

      /* Frame-metrics (één plek, hergebruikt door alle blokken) */
      :root {
        --frame-x: clamp(1.5rem, 4.5vw, 5.5rem);
        --frame-gap: clamp(2rem, 3.5vw, 3.5rem);
        --frame-top: clamp(2rem, 3.5vw, 3.5rem);
      }

      /* ---------- Logo mark (mask-image, token-gestuurd kleuren) ---------- */
      .logo-mark {
        display: inline-block;
        background-color: var(--fg);
        -webkit-mask-image: url('/assets/logo.png');
                mask-image: url('/assets/logo.png');
        -webkit-mask-size: contain;
                mask-size: contain;
        -webkit-mask-repeat: no-repeat;
                mask-repeat: no-repeat;
        -webkit-mask-position: center;
                mask-position: center;
        aspect-ratio: 1 / 1;
        transition: background-color var(--duration) var(--easing);
      }
      .logo-mark--sm  { width: 40px; height: 40px; }
      .logo-mark--md  { width: clamp(72px, 7.5vw, 104px); height: clamp(72px, 7.5vw, 104px); }
      .logo-mark--lg  { width: clamp(120px, 14vw, 180px); height: clamp(120px, 14vw, 180px); }
      .logo-mark--accent { background-color: var(--accent); }
      .logo-mark--on-deep,
      .band--deep .logo-mark { background-color: var(--fg-inverse); }

      /* ---------- Header ---------- */
      .site-header {
        position: sticky;
        top: 0;
        z-index: 50;
        margin: var(--frame-top) var(--frame-x) var(--frame-gap);
        background: transparent;
      }
      .site-header__inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-block: 0.65rem;
        padding-inline: clamp(1.25rem, 3vw, 2.5rem);
        max-width: none;
      }
      .site-header__logo {
        display: inline-flex;
        align-items: center;
      }
      .site-header__nav {
        display: flex;
        gap: clamp(1rem, 2.5vw, 2.5rem);
        font-size: 0.85rem;
        font-weight: 500;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }
      @media (max-width: 640px) {
        .site-header__nav { display: none; }
      }

      /* ---------- Band system (elk blok = los kaart-paneel op Sand-frame) ---------- */
      main { display: block; }

      .band {
        margin: 0 var(--frame-x) var(--frame-gap);
        padding-block: clamp(3.5rem, 7vw, 6rem);
        padding-inline: 0;
      }
      .band--light { background: var(--bg); color: var(--fg); }
      .band--alt { background: var(--bg); color: var(--fg); }
      .band--deep {
        background: var(--bg-deep);
        color: var(--fg-inverse);
      }
      .band--deep h2,
      .band--deep h3,
      .band--deep p { color: var(--fg-inverse); }

      /* Inner container binnen een band — niet dubbel inset */
      .band .container {
        max-width: 1120px;
      }

      /* ---------- Hero ---------- */
      .hero {
        display: grid;
        grid-template-columns: 1.1fr 1fr;
        gap: clamp(2rem, 6vw, 5rem);
        align-items: center;
      }
      .hero__copy > .logo-mark {
        display: block;
        margin-bottom: 0.5rem;
        margin-left: -0.25rem;
      }
      .hero__copy h1 {
        margin-block: 1rem 1.5rem;
      }
      .hero__copy h1 em {
        font-style: italic;
      }
      .hero__copy .lead {
        font-size: clamp(1.1rem, 1.6vw, 1.35rem);
        color: var(--fg);
        font-weight: 500;
        margin-bottom: 1rem;
        max-width: 52ch;
      }
      .hero__copy p {
        color: var(--muted);
        margin-bottom: 1rem;
      }
      .hero__cta {
        display: flex;
        gap: 1rem;
        margin-top: 2rem;
        flex-wrap: wrap;
      }
      .hero__visual {
        position: relative;
      }
      @media (max-width: 860px) {
        .hero { grid-template-columns: 1fr; }
        .hero__visual { max-width: 480px; margin-inline: auto; width: 100%; }
      }

      /* ---------- Split layout (Our Story / Our Philosophy) ---------- */
      .split {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: clamp(2rem, 6vw, 6rem);
        align-items: center;
      }
      .split--image-left .split__media { order: 0; }
      .split--image-left .split__copy { order: 1; }
      .split--image-right .split__media { order: 1; }
      .split--image-right .split__copy { order: 0; }

      .split__copy .eyebrow { display: block; margin-bottom: 1.25rem; }
      .split__copy h2 { margin-bottom: 1.75rem; }
      .split__copy h2 em { font-style: italic; color: var(--accent); }
      .split__copy p + p { margin-top: 1rem; }
      .split__copy p { color: var(--fg); opacity: 0.85; }

      @media (max-width: 860px) {
        .split { grid-template-columns: 1fr; }
        .split--image-left .split__media,
        .split--image-right .split__media { order: 0; }
        .split--image-left .split__copy,
        .split--image-right .split__copy { order: 1; }
        .split__media { max-width: 480px; margin-inline: auto; width: 100%; }
      }

      /* ---------- Showcase (SEREIN-style deep band) ---------- */
      .showcase {
        text-align: center;
      }
      .showcase__heading {
        max-width: 720px;
        margin: 0 auto 4rem;
      }
      .showcase__heading h2 { margin-top: 1rem; }
      .showcase__grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: clamp(1.5rem, 3vw, 2.5rem);
        margin-bottom: 4rem;
      }
      .pillar {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
      }
      .pillar h3 {
        font-size: clamp(1rem, 1.25vw, 1.15rem);
      }
      .showcase__body {
        max-width: 680px;
        margin: 0 auto;
        opacity: 0.92;
      }
      @media (max-width: 860px) {
        .showcase__grid { grid-template-columns: 1fr; max-width: 420px; margin-inline: auto; margin-bottom: 3rem; }
      }

      /* ---------- Services preview ---------- */
      .services__heading {
        max-width: 640px;
        margin-bottom: clamp(3rem, 6vw, 5rem);
      }
      .services__heading h2 { margin-top: 1rem; }
      .services__grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: clamp(1.5rem, 3vw, 3rem);
      }
      .service-card {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
      }
      .service-card__body h3 {
        margin-bottom: 0.75rem;
        font-size: clamp(1.1rem, 1.4vw, 1.3rem);
      }
      .service-card__body p {
        color: var(--fg);
        opacity: 0.8;
        margin-bottom: 1.25rem;
      }
      .service-card__body .subtle {
        color: var(--muted);
        font-style: italic;
        font-size: 0.85em;
      }
      @media (max-width: 860px) {
        .services__grid { grid-template-columns: 1fr; max-width: 480px; margin-inline: auto; }
      }

      /* ---------- Feature list (Voor wie) ---------- */
      .feature-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
      }
      .feature-list li {
        position: relative;
        padding-left: 2rem;
        font-size: 1.1rem;
        line-height: 1.55;
      }
      .feature-list li::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0.75em;
        width: 1rem;
        height: 1px;
        background: var(--accent);
      }

      /* ---------- CTA ---------- */
      .cta {
        text-align: center;
        max-width: 720px;
      }
      .cta h2 { margin-block: 1rem 1.5rem; }
      .cta p { opacity: 0.9; margin-bottom: 2rem; }

      /* ---------- Buttons ---------- */
      .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.95rem 1.75rem;
        font-family: var(--font-body);
        font-size: 0.85rem;
        font-weight: 600;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        border-radius: var(--radius-sm);
        transition: all var(--duration) var(--easing);
        border: 1px solid transparent;
      }
      .btn--primary {
        background: var(--fg);
        color: var(--bg);
      }
      .btn--primary:hover {
        background: var(--accent);
        color: var(--fg);
      }
      .btn--ghost {
        background: transparent;
        color: var(--fg);
        border-color: var(--fg);
      }
      .btn--ghost:hover {
        background: var(--fg);
        color: var(--bg);
      }
      .btn--inverse {
        background: var(--fg-inverse);
        color: var(--fg);
      }
      .btn--inverse:hover {
        background: var(--accent);
        color: var(--fg);
      }

      /* ---------- Link arrow ---------- */
      .link-arrow {
        font-family: var(--font-body);
        font-size: 0.85rem;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--fg);
        border-bottom: 1px solid var(--border);
        padding-bottom: 0.25rem;
        transition: all var(--duration) var(--easing);
      }
      .link-arrow::after {
        content: ' →';
        display: inline-block;
        transition: transform var(--duration) var(--easing);
      }
      .link-arrow:hover {
        color: var(--accent);
        border-color: var(--accent);
      }
      .link-arrow:hover::after {
        transform: translateX(4px);
      }

      /* ---------- Placeholders ---------- */
      .placeholder {
        position: relative;
        background:
          linear-gradient(135deg,
            color-mix(in srgb, var(--accent) 18%, var(--bg-alt)) 0%,
            color-mix(in srgb, var(--accent) 45%, var(--bg-deep)) 100%);
        border-radius: var(--radius-sm);
        overflow: hidden;
        width: 100%;
        display: flex;
        align-items: flex-end;
        padding: 1.25rem;
      }
      .placeholder--portrait { aspect-ratio: 3 / 4; }
      .placeholder--square { aspect-ratio: 1 / 1; }
      .placeholder--wide { aspect-ratio: 16 / 9; }
      .placeholder .eyebrow {
        color: var(--fg-inverse);
        opacity: 0.85;
        font-size: 0.7rem;
      }
      .placeholder--on-deep {
        background:
          linear-gradient(135deg,
            color-mix(in srgb, var(--fg) 20%, var(--bg-deep)) 0%,
            color-mix(in srgb, var(--fg) 45%, var(--bg-deep)) 100%);
      }

      /* ---------- Eyebrow variants ---------- */
      .eyebrow--inverse {
        color: var(--fg-inverse);
        opacity: 0.85;
      }

      /* ---------- Footer ---------- */
      .site-footer {
        margin: 0 var(--frame-x) var(--frame-top);
        background: var(--bg);
        padding-block: clamp(2.5rem, 5vw, 4rem);
        color: var(--fg);
      }
      .site-footer__inner {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        gap: 2rem;
        align-items: center;
      }
      .site-footer__logo {
        display: inline-flex;
        align-items: center;
      }
      .site-footer__logo .logo-mark { width: 72px; height: 72px; }
      .site-footer__nav {
        display: flex;
        gap: clamp(1rem, 2.5vw, 2.5rem);
        justify-content: center;
        flex-wrap: wrap;
      }
      .site-footer__nav a {
        font-size: 0.75rem;
        font-weight: 500;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--fg);
      }
      .site-footer__mail {
        text-align: right;
        font-size: 0.9rem;
        color: var(--muted);
      }
      .site-footer__mail a { color: var(--fg); border-bottom: 1px solid var(--border); }
      @media (max-width: 860px) {
        .site-footer__inner {
          grid-template-columns: 1fr;
          text-align: center;
        }
        .site-footer__mail { text-align: center; }
      }
    </style>
  </body>
</html>
