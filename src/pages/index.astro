              <figcaption>— [Naam], [Bedrijf]</figcaption>
            </figure>
            <figure class="quote" data-quote>
              <blockquote>“Iemand die écht overzicht brengt.”</blockquote>
              <figcaption>— [Naam], [Bedrijf]</figcaption>
            </figure>
            <figure class="quote" data-quote>
              <blockquote>“Degene die ervoor zorgt dat het afkomt.”</blockquote>
              <figcaption>— [Naam], [Bedrijf]</figcaption>
            </figure>
            <figure class="quote" data-quote>
              <blockquote>“[Placeholder quote 4 — vervang met echte testimonial.]”</blockquote>
              <figcaption>— [Naam], [Bedrijf]</figcaption>
            </figure>
            <figure class="quote" data-quote>
              <blockquote>“[Placeholder quote 5 — vervang met echte testimonial.]”</blockquote>
              <figcaption>— [Naam], [Bedrijf]</figcaption>
            </figure>
            <figure class="quote" data-quote>
              <blockquote>“[Placeholder quote 6 — vervang met echte testimonial.]”</blockquote>
              <figcaption>— [Naam], [Bedrijf]</figcaption>
            </figure>
            <figure class="quote" data-quote>
              <blockquote>“[Placeholder quote 7 — vervang met echte testimonial.]”</blockquote>
              <figcaption>— [Naam], [Bedrijf]</figcaption>
            </figure>
          </div>

          <div class="quotes__controls">
            <button type="button" class="carousel__arrow" data-quote-prev aria-label="Vorige quote">←</button>
            <button type="button" class="carousel__arrow" data-quote-next aria-label="Volgende quote">→</button>
