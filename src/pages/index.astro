              <button type="button" class="carousel__arrow" data-carousel-next aria-label="Volgende projecten">→</button>
            </div>
          </header>

          <div class="carousel__track" tabindex="0" aria-label="Projecten">

            <article class="project-card">
              <span class="project-card__num">01 · Agency</span>
