---
const title = "{{PROJECT_NAME}}";
const description = "Kort beschrijving van de site. Wordt in Fase 6 vervangen door /copywriting.";
const domain = "{{DOMAIN}}";
---

<!DOCTYPE html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={`https://${domain}/`} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={`https://${domain}/`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`https://${domain}/og-preview.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content={title} />
    <meta property="og:locale" content="nl_NL" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`https://${domain}/og-preview.png`} />

    <link rel="icon" href="/favicon.png" />

    <script is:inline>
      const saved = localStorage.getItem('theme');
      if (saved) document.documentElement.setAttribute('data-theme', saved);
    </script>

    <style is:global>
      :root {
        --bg: #ffffff;
        --fg: #111111;
        --accent: #000000;
        --muted: #666666;
        --border: #e5e5e5;
      }
      [data-theme="dark"] {
        --bg: #0b0b0b;
        --fg: #f5f5f5;
        --accent: #ffffff;
        --muted: #888888;
        --border: #222222;
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: system-ui, -apple-system, sans-serif;
        background: var(--bg);
        color: var(--fg);
        line-height: 1.6;
      }
      main {
        max-width: 720px;
        margin: 0 auto;
        padding: clamp(2rem, 6vw, 6rem) 1.5rem;
      }
      h1 { font-size: clamp(2rem, 5vw, 3.5rem); line-height: 1.1; margin-bottom: 1rem; }
      p { color: var(--muted); }
      .tag { display: inline-block; padding: 0.25rem 0.75rem; border: 1px solid var(--border); border-radius: 999px; font-size: 0.875rem; margin-bottom: 1.5rem; }
    </style>
  </head>
  <body>
    <main>
      <span class="tag">Scaffold via /website-quicklaunch</span>
      <h1>{title}</h1>
      <p>
        Dit is een lege scaffold. De design system, visuele richting en copy worden stap-voor-stap
        ingevuld via de /website-quicklaunch flow (Fase 4–7).
      </p>
    </main>
  </body>
</html>
