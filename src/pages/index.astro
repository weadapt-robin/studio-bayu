      <!-- ============ CTA / CONTACT (id=contact) ============ -->
      <section id="contact" class="band band--deep fade-up">
        <div class="container cta">
          <span class="eyebrow">Kennismaken</span>
          <h2>Klaar om je operatie in beweging te brengen?</h2>
          <p>
            Wil je weten of Studio Bayu past bij jouw organisatie of project? Neem contact op
            voor een kennismaking.
          </p>
          <div class="cta__actions">
            <a href="mailto:lize@studiobayu.com" class="btn btn--primary">Mail Lize</a>
            <a href="mailto:lize@studiobayu.com?subject=Kennismaking%20Studio%20Bayu" class="btn btn--ghost">Plan een kennismaking</a>
          </div>
          <p class="cta__mail">
            <a href="mailto:lize@studiobayu.com">lize@studiobayu.com</a>
