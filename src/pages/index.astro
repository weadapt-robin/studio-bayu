---
import '../styles/globals.css';
import Inspector from '../components/Inspector.astro';

const title = "Studio Bayu — Brengt projecten in beweging";
const description = "Operations & (lead) projectmanagement voor agencies en brands. Studio Bayu structureert, stuurt en realiseert complexe projecten.";
const domain = "studiobayu.com";
---

<!DOCTYPE html>
<html lang="nl" data-theme="serein">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={`https://${domain}/`} />

    <link rel="preload" href="/fonts/TAN-Nimbus.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/Quicksand-Regular.ttf" as="font" type="font/ttf" crossorigin />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={`https://${domain}/`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`https://${domain}/og-preview.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Studio Bayu" />
    <meta property="og:locale" content="nl_NL" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`https://${domain}/og-preview.png`} />

    <link rel="icon" href="/favicon.png" />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {"@type":"ListItem","position":1,"name":"Home","item":`https://${domain}`}
      ]
    })} />
  </head>
  <body>
    <header class="site-header">
      <div class="container site-header__inner">
        <a href="#home" class="site-header__logo">Studio Bayu</a>
        <nav class="site-header__nav" aria-label="Hoofdnavigatie">
          <a href="#home">Home</a>
          <div class="nav-item nav-item--dropdown">
            <a href="#expertise" class="nav-item__link" aria-haspopup="true">Expertise</a>
            <ul class="nav-dropdown" role="menu">
              <li role="none"><a href="#expertise-projectmanagement" role="menuitem">(Lead) Projectmanagement</a></li>
              <li role="none"><a href="#expertise-operations" role="menuitem">Operations &amp; procesoptimalisatie</a></li>
              <li role="none"><a href="#expertise-events" role="menuitem">Events &amp; weddings</a></li>
            </ul>
          </div>
          <a href="#projecten">Projecten</a>
          <a href="#ervaringen">Ervaringen</a>
          <a href="#contact">Contact</a>
        </nav>
      </div>
    </header>

    <main>

      <!-- ============ HERO (id=home) ============ -->
      <section id="home" class="band band--light band--hero">
        <div class="container hero hero--centered">
          <div class="hero__copy">
            <span class="logo-mark logo-mark--md" role="img" aria-label="Studio Bayu"></span>
            <h1>Brengt projecten<br /> in beweging.</h1>
            <p class="lead">
              Operations &amp; (lead) projectmanagement voor agencies en brands.
            </p>
            <p>
              Ik help teams en organisaties om complexe projecten te structureren, aan te sturen
              en te realiseren. Van strategie tot uitvoering. Met focus op overzicht,
              samenwerking en een soepel lopende operatie.
            </p>
            <div class="hero__cta">
              <a href="#contact" class="btn btn--primary">Kennismaken</a>
              <a href="#expertise" class="btn btn--ghost">Expertise</a>
            </div>
          </div>
        </div>
      </section>

      <!-- ============ INTRODUCTIE (id=introductie) ============ -->
      <section id="introductie" class="band band--deep">
        <div class="container split split--image-left fade-up">
          <div class="split__media">
            <img
              src="/assets/studio_bayu.JPG"
              alt="Lize van den Heuvel — Studio Bayu"
              class="split__img split__img--portrait"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="split__copy">
            <span class="eyebrow">Introductie</span>
            <h2>Over Studio Bayu</h2>
            <p>
              Ik ben <strong>Lize van den Heuvel</strong>, project- en operations specialist.
              Ik help agencies en brands om projecten helder te structureren, teams beter te
              laten samenwerken en de operatie strak georganiseerd te krijgen.
            </p>
            <p>
              Mijn rol zit vaak tussen strategie en uitvoering in: ik vertaal plannen naar
              werkbare structuren en zorg dat ze ook echt worden uitgevoerd.
            </p>
            <p>
              In veel agencies en creatieve organisaties zit de uitdaging niet in ideeën,
              maar in uitvoering. Projecten lopen parallel, prioriteiten verschuiven, teams
              schakelen constant en overzicht raakt versnipperd. Studio Bayu brengt daar
              structuur in.
            </p>
          </div>
        </div>
      </section>

      <!-- ============ WERKWIJZE (id=werkwijze) ============ -->
      <section id="werkwijze" class="band band--light fade-up">
        <div class="container showcase">
          <div class="showcase__heading">
            <span class="eyebrow eyebrow--inverse">Werkwijze</span>
            <h2>Hoe werkt Studio Bayu?</h2>
          </div>
          <div class="showcase__grid">
            <figure class="pillar">
              <img
                src="/assets/DSCF2628.JPG"
                alt="Heldere structuren — Studio Bayu werkwijze"
                class="pillar__img"
                loading="lazy"
                decoding="async"
              />
              <figcaption>
                <h3>Heldere structuren</h3>
              </figcaption>
            </figure>
            <figure class="pillar">
              <img
                src="/assets/DSCF2287.JPG"
                alt="Sterke aansturing — Studio Bayu werkwijze"
                class="pillar__img"
                loading="lazy"
                decoding="async"
              />
              <figcaption>
                <h3>Sterke aansturing</h3>
              </figcaption>
            </figure>
            <figure class="pillar">
              <img
                src="/assets/DSCF2292.JPG"
                alt="Voorspelbare uitvoering — Studio Bayu werkwijze"
                class="pillar__img"
                loading="lazy"
                decoding="async"
              />
              <figcaption>
                <h3>Voorspelbare uitvoering</h3>
              </figcaption>
            </figure>
          </div>
          <div class="showcase__body">
            <p>
              Mijn aanpak is direct, analytisch en betrokken. Ik begin altijd met het begrijpen
              van het systeem: hoe werkt een team, waar zit de frictie, waar gaat energie
              verloren?
            </p>
            <p>
              Van daaruit bouw ik structuur die past bij hoe een organisatie écht werkt,
              niet hoe het op papier zou moeten zijn. Zodat teams beter kunnen werken en
              projecten minder afhankelijk zijn van ad hoc schakelen.
            </p>
          </div>
        </div>
      </section>

      <!-- ============ EXPERTISE (id=expertise) ============ -->
      <section id="expertise" class="band band--deep">
        <div class="container services">
          <header class="services__heading fade-up">
            <span class="eyebrow">Expertise</span>
            <h2>Drie manieren waarop ik werk.</h2>
          </header>

          <div class="services__grid">

            <article id="expertise-projectmanagement" class="service-card fade-up">
              <div class="placeholder placeholder--portrait">
                <span class="eyebrow">01</span>
              </div>
              <div class="service-card__body">
                <h3>(Lead) Projectmanagement</h3>
                <p>
                  Ik stuur projecten van begin tot eind aan en bewaak planning, scope, budget
                  en kwaliteit. Van het vertalen van strategie naar concrete planning tot
                  dagelijkse coördinatie en stakeholdermanagement.
                </p>
                <details class="service-expand">
                  <summary>
                    <span class="service-expand__label">Meer over projectmanagement</span>
                  </summary>
                  <div class="service-expand__body">
                    <p>
                      Ik neem verantwoordelijkheid voor de uitvoering van projecten van begin
                      tot eind. Dat betekent:
                    </p>
                    <ul>
                      <li>vertaling van strategie naar planning</li>
                      <li>aansturing van teams en klanten</li>
                      <li>bewaking van scope, budget en timing</li>
                      <li>continue afstemming met stakeholders</li>
                    </ul>
                    <p>
                      Ik werk als projectmanager of lead binnen bestaande structuren en teams.
                    </p>
                  </div>
                </details>
              </div>
            </article>

            <article id="expertise-operations" class="service-card fade-up">
              <div class="placeholder placeholder--portrait">
                <span class="eyebrow">02</span>
              </div>
              <div class="service-card__body">
                <h3>Operations &amp; procesoptimalisatie</h3>
                <p>
                  Ik analyseer hoe teams en organisaties werken en breng structuur aan waar dat
                  ontbreekt. Denk aan workflow optimalisatie, interne processen, rolverdeling
                  en werkstructuren die schaalbaar zijn.
                </p>
                <details class="service-expand">
                  <summary>
                    <span class="service-expand__label">Meer over operations</span>
                  </summary>
                  <div class="service-expand__body">
                    <p>
                      Sterke projecten vragen om sterke processen. Ik breng in kaart hoe teams
                      werken en optimaliseer de structuur erachter. Denk aan:
                    </p>
                    <ul>
                      <li>workflow en procesontwerp</li>
                      <li>rolverdeling en verantwoordelijkheden</li>
                      <li>interne communicatie en overdracht</li>
                      <li>schaalbare werkstructuren</li>
                    </ul>
                    <p>Doel: minder frictie, meer output.</p>
                  </div>
                </details>
              </div>
            </article>

            <article id="expertise-events" class="service-card fade-up">
              <div class="placeholder placeholder--portrait">
                <span class="eyebrow">03</span>
              </div>
              <div class="service-card__body">
                <h3>Events &amp; weddings</h3>
                <p>
                  Naast mijn werk voor agencies en brands begeleid ik events en bruiloften.
                  Altijd met dezelfde aanpak: overzicht, structuur en aandacht voor detail
                  in uitvoering.
                </p>
                <details class="service-expand">
                  <summary>
                    <span class="service-expand__label">Meer over events</span>
                  </summary>
                  <div class="service-expand__body">
                    <p>
                      Van concept tot productie. Voor brands die een event willen dat in elk
                      detail klopt, en voor privé-opdrachtgevers die hun dag professioneel
                      begeleid willen zien.
                    </p>
                    <ul>
                      <li>concept en draaiboek</li>
                      <li>leveranciers-coördinatie</li>
                      <li>planning en timing</li>
                      <li>on-site aansturing</li>
                    </ul>
                    <p>Selectief, zodat elk traject de aandacht krijgt die het verdient.</p>
                  </div>
                </details>
              </div>
            </article>

          </div>
        </div>
      </section>

      <!-- ============ VOOR WIE (id=voor-wie) ============ -->
      <section id="voor-wie" class="band band--light">
        <div class="container split split--image-right fade-up">
          <div class="split__copy">
            <span class="eyebrow">Voor wie</span>
            <h2>Studio Bayu werkt met…</h2>
            <ul class="feature-list">
              <li>agencies en brands die meerdere projecten tegelijk draaien</li>
              <li>teams met behoefte aan structuur in de operatie</li>
              <li>organisaties die willen opschalen zonder chaos</li>
              <li>opdrachtgevers die iemand zoeken die verantwoordelijkheid neemt in uitvoering</li>
            </ul>
          </div>
          <div class="split__media">
            <div class="placeholder placeholder--portrait">
              <span class="eyebrow">Afbeelding · placeholder</span>
