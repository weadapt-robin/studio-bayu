    </main>

    <!-- ============ FOOTER ============ -->
    <footer class="site-footer">
      <div class="container site-footer__inner">
        <a href="#home" class="site-footer__logo" aria-label="Studio Bayu, terug naar home">
          <span class="logo-mark logo-mark--md" aria-hidden="true"></span>
        </a>
        <nav class="site-footer__nav" aria-label="Footer">
          <a href="#expertise-projectmanagement">Projectmanagement</a>
          <a href="#expertise-operations">Operations</a>
          <a href="#expertise-events">Events</a>
          <a href="#contact">Contact</a>
        </nav>
        <p class="site-footer__mail">
          <a href="mailto:lize@studiobayu.com">lize@studiobayu.com</a>
        </p>
      </div>
    </footer>

    <Inspector />

    <script is:inline>
      // Fade-up on scroll
      const io = new IntersectionObserver((entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            io.unobserve(entry.target);
          }
        }
      }, { rootMargin: '-10% 0px', threshold: 0.05 });
      document.querySelectorAll('.fade-up').forEach((el) => io.observe(el));

      // Projecten carousel — horizontal scroll via arrows
      document.querySelectorAll('[data-carousel]').forEach((c) => {
        const track = c.querySelector('.carousel__track');
        const prev = c.querySelector('[data-carousel-prev]');
        const next = c.querySelector('[data-carousel-next]');
        if (!track) return;
        const step = () => {
          const first = track.querySelector('.project-card');
          if (!first) return 0;
          const gap = parseFloat(getComputedStyle(track).columnGap || getComputedStyle(track).gap || 0);
          return first.getBoundingClientRect().width + gap;
        };
        prev?.addEventListener('click', () => track.scrollBy({ left: -step(), behavior: 'smooth' }));
        next?.addEventListener('click', () => track.scrollBy({ left:  step(), behavior: 'smooth' }));
      });

      // Quote rotator — single quote visible, auto-rotate + manual arrows
      (function () {
        const stage = document.querySelector('[data-quotes]');
        if (!stage) return;
        const quotes = stage.querySelectorAll('[data-quote]');
        if (!quotes.length) return;
        let i = 0;
        let timer;
        const show = (idx) => {
          i = (idx + quotes.length) % quotes.length;
          quotes.forEach((q, j) => q.classList.toggle('is-active', j === i));
        };
        const start = () => { timer = setInterval(() => show(i + 1), 5500); };
        const reset = () => { clearInterval(timer); start(); };
        show(0);
        start();
        stage.querySelector('[data-quote-prev]')?.addEventListener('click', () => { show(i - 1); reset(); });
        stage.querySelector('[data-quote-next]')?.addEventListener('click', () => { show(i + 1); reset(); });
      })();
    </script>

    <style is:global>
      /* ==========================================================
         Homepage — page-specifieke styles
         (globale tokens + base zitten in src/styles/globals.css)
         ========================================================== */

      body {
        background: #c7c1b2;
      }

      :root {
        --frame-x: clamp(1.5rem, 4.5vw, 5.5rem);
        --frame-gap: clamp(3rem, 5vw, 5rem);
        --frame-top: clamp(0.4rem, 0.75vw, 0.75rem);
        --frame-header-gap: clamp(0.5rem, 1.25vw, 1.25rem);
        --grain-intensity: 0.38;
      }

      /* ---------- Smooth scroll + scroll-offset voor sticky header ---------- */
      html { scroll-padding-top: 5rem; }

      /* ---------- Logo mark (mask-image, token-gestuurd kleuren) ---------- */
      .logo-mark {
        display: inline-block;
        background-color: var(--fg);
        -webkit-mask-image: url('/assets/logo.png');
                mask-image: url('/assets/logo.png');
        -webkit-mask-size: contain;
                mask-size: contain;
        -webkit-mask-repeat: no-repeat;
                mask-repeat: no-repeat;
        -webkit-mask-position: center;
                mask-position: center;
        aspect-ratio: 1 / 1;
        transition: background-color var(--duration) var(--easing);
      }
      .logo-mark--sm  { width: 40px; height: 40px; }
      .logo-mark--md  { width: clamp(72px, 7.5vw, 104px); height: clamp(72px, 7.5vw, 104px); }
      .logo-mark--lg  { width: clamp(120px, 14vw, 180px); height: clamp(120px, 14vw, 180px); }
      .logo-mark--accent { background-color: var(--accent); }
      .logo-mark--on-deep,
      .band--deep .logo-mark { background-color: var(--fg-inverse); }

      /* ---------- Header ---------- */
      .site-header {
        position: sticky;
        top: 0;
        z-index: 50;
        margin: var(--frame-top) var(--frame-x) var(--frame-header-gap);
        background: transparent;
      }
      .site-header__inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-block: 0.65rem;
        padding-inline: clamp(1.25rem, 3vw, 2.5rem);
        max-width: none;
        gap: 2rem;
      }
      .site-header__logo {
        font-family: var(--font-display);
        font-size: clamp(1.25rem, 1.4vw, 1.5rem);
        letter-spacing: 0.005em;
        color: var(--fg);
      }
      .site-header__nav {
        display: flex;
        align-items: center;
        gap: clamp(1.25rem, 2.75vw, 2.75rem);
        font-size: 0.95rem;
        font-weight: 500;
        letter-spacing: 0.1em;
        text-transform: uppercase;
      }
      .site-header__nav a { color: var(--fg); }

      /* Dropdown onder Expertise */
      .nav-item { position: relative; }
      .nav-item__link { display: inline-block; }
      .nav-dropdown {
        position: absolute;
        top: 100%;
        left: 50%;
        transform: translate(-50%, -8px);
        min-width: 260px;
        margin: 0;
        padding: 0.5rem 0;
        list-style: none;
        background: var(--bg);
        border: 1px solid var(--border);
        box-shadow: var(--shadow-md);
        opacity: 0;
        visibility: hidden;
        transition: opacity var(--duration) var(--easing),
                    transform var(--duration) var(--easing),
                    visibility var(--duration) var(--easing);
        z-index: 100;
      }
      .nav-item--dropdown:hover .nav-dropdown,
      .nav-item--dropdown:focus-within .nav-dropdown {
        opacity: 1;
        visibility: visible;
        transform: translate(-50%, 0);
      }
      .nav-dropdown li { margin: 0; }
      .nav-dropdown a {
        display: block;
        padding: 0.7rem 1.25rem;
        font-size: 0.78rem;
        font-weight: 500;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--fg);
        white-space: nowrap;
        transition: background var(--duration) var(--easing), color var(--duration) var(--easing);
      }
      .nav-dropdown a:hover {
        background: var(--bg-warm);
        color: var(--accent);
      }
      @media (max-width: 860px) {
        .site-header__nav { display: none; }
      }

      /* ---------- Band system ---------- */
      main { display: block; }

      .band {
        position: relative;
        isolation: isolate;
        margin: 0 var(--frame-x) var(--frame-gap);
        padding-block: clamp(3.5rem, 7vw, 6rem);
        padding-inline: 0;
        scroll-margin-top: 5rem;
      }
      .band--light { background: var(--bg); color: var(--fg); }
      /* band--alt is in de 2-cyclus Serein-layout een alias voor deep */
      .band--alt { background: var(--bg-warm); color: var(--fg-inverse); }
      .band--deep {
        background: var(--bg-deep);
        color: var(--fg-inverse);
      }
      .band--deep h2,
      .band--deep h3,
      .band--deep p { color: var(--fg-inverse); }

      /* Component-overrides binnen deep bands (2-cyclus layout) */
      .band--deep .split__copy p,
      .band--deep .service-card__body p,
      .band--deep .service-expand__label,
      .band--deep .service-expand__body,
      .band--deep .service-expand__body p,
      .band--deep .service-expand__body li,
      .band--deep .feature-list li {
        color: var(--fg-inverse);
      }
      .band--deep .service-expand {
        border-top-color: color-mix(in srgb, var(--fg-inverse) 30%, transparent);
      }
      .band--deep .btn--ghost {
        color: var(--fg-inverse);
        border-color: var(--fg-inverse);
      }
      .band--deep .btn--ghost:hover {
        background: var(--fg-inverse);
        color: var(--fg);
      }

      .band::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image: url('/assets/paper-texture.jpg');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        mix-blend-mode: multiply;
        opacity: var(--grain-intensity);
        pointer-events: none;
        z-index: 0;
      }

      .band--deep::after {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse at center, transparent 55%, rgba(0, 0, 0, 0.08) 100%);
        pointer-events: none;
        z-index: 0;
      }

      .band > * { position: relative; z-index: 1; }

      .band .container {
        max-width: 1120px;
      }

      /* ---------- Hero (gecentreerd, zonder media) ---------- */
      .hero--centered {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
      }
      .hero--centered .hero__copy {
        max-width: 780px;
        display: flex;
        flex-direction: column;
        align-items: center;
      }
      .hero__copy > .logo-mark {
        display: block;
        margin-bottom: 0.75rem;
      }
      .hero__copy h1 {
        margin-block: 1rem 1.5rem;
      }
      .hero__copy h1 em { font-style: italic; }
      .hero__copy .lead {
        font-size: clamp(1.1rem, 1.6vw, 1.35rem);
        color: var(--fg);
        font-weight: 500;
        margin-bottom: 1rem;
        max-width: 52ch;
      }
      .hero__copy p {
        color: var(--muted);
        margin-bottom: 1rem;
        max-width: 62ch;
      }
      .hero__cta {
        display: flex;
        gap: 1rem;
        margin-top: 2rem;
        flex-wrap: wrap;
        justify-content: center;
      }

      /* ---------- Split layout ---------- */
      .split {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: clamp(2rem, 6vw, 6rem);
        align-items: center;
      }
      .split--image-left .split__media { order: 0; }
      .split--image-left .split__copy { order: 1; }
      .split--image-right .split__media { order: 1; }
      .split--image-right .split__copy { order: 0; }
      .split__copy .eyebrow { display: block; margin-bottom: 1.25rem; }
      .split__copy h2 { margin-bottom: 1.75rem; }
      .split__copy h2 em { font-style: italic; color: var(--accent); }
      .split__copy p + p { margin-top: 1rem; }
      .split__copy p { color: var(--fg); opacity: 0.9; }
      @media (max-width: 860px) {
        .split { grid-template-columns: 1fr; }
        .split--image-left .split__media,
        .split--image-right .split__media { order: 0; }
        .split--image-left .split__copy,
        .split--image-right .split__copy { order: 1; }
        .split__media { max-width: 480px; margin-inline: auto; width: 100%; }
      }

      /* ---------- Showcase (Werkwijze) ---------- */
      .showcase { text-align: center; }
      .showcase__heading {
        max-width: 720px;
        margin: 0 auto 4rem;
      }
      .showcase__heading h2 { margin-top: 1rem; }
      .showcase__grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: clamp(1.5rem, 3vw, 2.5rem);
        margin-bottom: 4rem;
      }
      .pillar {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
      }
      .pillar h3 {
        font-size: clamp(1rem, 1.25vw, 1.15rem);
      }
      .showcase__body {
        max-width: 680px;
        margin: 0 auto;
        opacity: 0.92;
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }
      @media (max-width: 860px) {
        .showcase__grid { grid-template-columns: 1fr; max-width: 420px; margin-inline: auto; margin-bottom: 3rem; }
      }

      /* ---------- Expertise (services) ---------- */
      .services__heading {
        max-width: 640px;
        margin-bottom: clamp(3rem, 6vw, 5rem);
      }
      .services__heading h2 { margin-top: 1rem; }
      .services__grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: clamp(1.5rem, 3vw, 3rem);
        align-items: start;
      }
      .service-card {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
      }
      .service-card__body h3 {
        margin-bottom: 0.75rem;
        font-size: clamp(1.1rem, 1.4vw, 1.3rem);
      }
      .service-card__body p {
        color: var(--fg);
        opacity: 0.85;
        margin-bottom: 1.25rem;
      }

      /* Accordion via <details> */
      .service-expand {
        border-top: 1px solid var(--border);
        margin-top: 0.5rem;
      }
      .service-expand[open] { border-color: color-mix(in srgb, var(--accent) 50%, transparent); }
      .service-expand > summary {
        list-style: none;
        cursor: pointer;
        padding: 0.9rem 0;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        transition: color var(--duration) var(--easing);
      }
      .service-expand > summary::-webkit-details-marker { display: none; }
      .service-expand__label {
        font-family: var(--font-body);
        font-size: 0.82rem;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--fg);
      }
      .service-expand > summary::after {
        content: '+';
        font-family: var(--font-body);
        font-size: 1.1rem;
        font-weight: 500;
        color: var(--accent);
        transition: transform var(--duration) var(--easing);
      }
      .service-expand[open] > summary::after { transform: rotate(45deg); }
      .service-expand > summary:hover .service-expand__label { color: var(--accent); }
      .service-expand__body {
        padding: 0.5rem 0 1.25rem;
        display: flex;
        flex-direction: column;
        gap: 0.9rem;
      }
      .service-expand__body ul {
        list-style: none;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
      }
      .service-expand__body li {
        position: relative;
        padding-left: 1.5rem;
        font-size: 0.95rem;
      }
      .service-expand__body li::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0.7em;
        width: 0.6rem;
        height: 1px;
        background: var(--accent);
      }

      @media (max-width: 860px) {
        .services__grid { grid-template-columns: 1fr; max-width: 480px; margin-inline: auto; }
      }

      /* ---------- Feature list (Voor wie) ---------- */
      .feature-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
      }
      .feature-list li {
        position: relative;
        padding-left: 2rem;
        font-size: 1.05rem;
        line-height: 1.55;
      }
      .feature-list li::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0.75em;
        width: 1rem;
        height: 1px;
        background: var(--accent);
      }

      /* ---------- Projecten carousel ---------- */
      .carousel__heading {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 2rem;
        margin-bottom: clamp(2rem, 4vw, 3rem);
      }
      .carousel__heading h2 { margin-top: 0.75rem; }
      .carousel__controls {
        display: flex;
        gap: 0.75rem;
        flex-shrink: 0;
      }
      .carousel__arrow {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        border: 1px solid currentColor;
        background: transparent;
        color: inherit;
        cursor: pointer;
        font-size: 1.05rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: background var(--duration) var(--easing),
                    color var(--duration) var(--easing),
                    transform var(--duration) var(--easing);
      }
      .carousel__arrow:hover {
        background: currentColor;
      }
      .band--deep .carousel__arrow:hover { color: var(--bg-deep); }
      .band--light .carousel__arrow:hover,
      .band--alt .carousel__arrow:hover { color: var(--bg); }
      .carousel__arrow:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
      }

      .carousel__track {
        display: grid;
        grid-auto-flow: column;
        grid-auto-columns: calc((100% - 2 * clamp(1rem, 2vw, 2rem)) / 3);
        gap: clamp(1rem, 2vw, 2rem);
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        scrollbar-width: none;
        -ms-overflow-style: none;
        padding-bottom: 0.5rem;
      }
      .carousel__track::-webkit-scrollbar { display: none; }

      .project-card {
        scroll-snap-align: start;
        padding: clamp(1.5rem, 2.5vw, 2rem);
        background: var(--bg);
        color: var(--fg);
        display: flex;
        flex-direction: column;
        gap: 0.85rem;
        min-height: 260px;
      }
      .project-card__num {
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--muted);
      }
      .project-card h3 {
        font-size: clamp(1.05rem, 1.3vw, 1.25rem);
        color: var(--fg);
      }
      .project-card p {
        font-size: 0.95rem;
        color: var(--fg);
        opacity: 0.85;
        flex: 1;
      }
      .project-card__meta {
        font-size: 0.75rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--muted);
        padding-top: 0.5rem;
        border-top: 1px solid var(--border);
      }

      @media (max-width: 960px) {
        .carousel__track { grid-auto-columns: calc((100% - 1rem) / 2); }
      }
      @media (max-width: 640px) {
        .carousel__heading { flex-direction: column; align-items: flex-start; }
        .carousel__track { grid-auto-columns: 85%; }
      }

      /* ---------- Ervaringen quote rotator ---------- */
      .quotes {
        text-align: center;
        max-width: 820px;
      }
      .quotes__heading { margin-bottom: clamp(2.5rem, 5vw, 4rem); }
      .quotes__heading h2 { margin-top: 0.75rem; }

      .quotes__stage {
        position: relative;
        min-height: 260px;
      }
      .quote {
        position: absolute;
        inset: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 1.5rem;
        opacity: 0;
        transform: translateY(12px);
        transition: opacity 0.6s var(--easing), transform 0.6s var(--easing);
        pointer-events: none;
      }
      .quote.is-active {
        opacity: 1;
        transform: none;
        pointer-events: auto;
      }
      .quote blockquote {
        font-family: var(--font-display);
        font-size: clamp(1.35rem, 2.2vw, 1.9rem);
        line-height: 1.35;
        color: var(--fg);
        max-width: 680px;
        margin: 0;
      }
      .quote figcaption {
        font-size: 0.8rem;
        font-weight: 500;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--muted);
      }

      .quotes__controls {
        display: flex;
        gap: 1rem;
        justify-content: center;
        margin-top: clamp(1.5rem, 3vw, 2.5rem);
      }

      /* ---------- CTA ---------- */
      .cta {
        text-align: center;
        max-width: 720px;
      }
      .cta h2 { margin-block: 1rem 1.5rem; }
      .cta p { opacity: 0.9; margin-bottom: 2rem; }
      .cta__actions {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
        margin-bottom: 2rem;
      }
      .cta__mail {
        font-size: 0.9rem;
        color: var(--muted);
        margin-bottom: 0;
      }
      .cta__mail a {
        color: var(--fg);
        border-bottom: 1px solid var(--border);
      }

      /* ---------- Buttons ---------- */
      .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.95rem 1.75rem;
        font-family: var(--font-body);
        font-size: 0.85rem;
        font-weight: 600;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        border-radius: var(--radius-sm);
        transition: all var(--duration) var(--easing);
        border: 1px solid transparent;
      }
      .btn--primary { background: var(--fg); color: var(--bg); }
      .btn--primary:hover { background: var(--accent); color: var(--fg); }
      .btn--ghost { background: transparent; color: var(--fg); border-color: var(--fg); }
      .btn--ghost:hover { background: var(--fg); color: var(--bg); }
      .btn--inverse { background: var(--fg-inverse); color: var(--fg); }
      .btn--inverse:hover { background: var(--accent); color: var(--fg); }

      /* ---------- Placeholders ---------- */
      .placeholder {
        position: relative;
        background:
          linear-gradient(135deg,
            color-mix(in srgb, var(--accent) 18%, var(--bg-alt)) 0%,
            color-mix(in srgb, var(--accent) 45%, var(--bg-deep)) 100%);
        border-radius: var(--radius-sm);
        overflow: hidden;
        width: 100%;
        display: flex;
        align-items: flex-end;
        padding: 1.25rem;
      }
      .placeholder--portrait { aspect-ratio: 3 / 4; }
      .placeholder--square { aspect-ratio: 1 / 1; }
      .placeholder--wide { aspect-ratio: 16 / 9; }
      .split__img {
        width: 100%;
        height: auto;
        display: block;
        border-radius: var(--radius-sm);
        object-fit: cover;
      }
      .split__img--portrait { aspect-ratio: 3 / 4; }
      .pillar__img {
        width: 100%;
        aspect-ratio: 1 / 1;
        object-fit: cover;
        display: block;
        border-radius: var(--radius-sm);
      }
      .placeholder .eyebrow {
        color: var(--fg-inverse);
        opacity: 0.85;
        font-size: 0.7rem;
      }
      .placeholder--on-deep {
        background:
          linear-gradient(135deg,
            color-mix(in srgb, var(--fg) 20%, var(--bg-deep)) 0%,
            color-mix(in srgb, var(--fg) 45%, var(--bg-deep)) 100%);
      }

      /* ---------- Eyebrow variants ---------- */
      .eyebrow--inverse {
        color: var(--fg-inverse);
        opacity: 0.85;
      }

      /* ---------- Footer ---------- */
      .site-footer {
        margin: 0 var(--frame-x) var(--frame-top);
        background: var(--bg);
        padding-block: clamp(2.5rem, 5vw, 4rem);
        color: var(--fg);
        position: relative;
        isolation: isolate;
      }
      .site-footer::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image: url('/assets/paper-texture.jpg');
        background-size: cover;
        background-position: center;
        mix-blend-mode: multiply;
        opacity: var(--grain-intensity);
        pointer-events: none;
        z-index: 0;
      }
      .site-footer > * { position: relative; z-index: 1; }
      .site-footer__inner {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        gap: 2rem;
        align-items: center;
      }
      .site-footer__logo {
        display: inline-flex;
        align-items: center;
      }
      .site-footer__logo .logo-mark { width: 72px; height: 72px; }
      .site-footer__nav {
        display: flex;
        gap: clamp(1rem, 2.5vw, 2.5rem);
        justify-content: center;
        flex-wrap: wrap;
      }
      .site-footer__nav a {
        font-size: 0.75rem;
        font-weight: 500;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--fg);
      }
      .site-footer__mail {
        text-align: right;
        font-size: 0.9rem;
        color: var(--muted);
      }
      .site-footer__mail a { color: var(--fg); border-bottom: 1px solid var(--border); }
      @media (max-width: 860px) {
        .site-footer__inner { grid-template-columns: 1fr; text-align: center; }
        .site-footer__mail { text-align: center; }
      }
    </style>
  </body>
</html>
